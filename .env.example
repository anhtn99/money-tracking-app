DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_tracking_app
ENVIRONMENT=local

# Get these from your Plaid dashboard (Team Settings -> Keys)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# Only needed for the Secrets Manager calls in app/core/secrets.py --
# locally, use your own AWS SSO/IAM credentials (same as your other projects)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token
AWS_DEFAULT_REGION=us-east-2
